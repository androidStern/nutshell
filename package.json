{
  "name": "nutshell",
  "version": "0.1.16",
  "description": "Local personal trace ingestion runtime for notes, media activity, podcasts, and X.",
  "type": "module",
  "bin": {
    "nutshell": "./bin/nutshell"
  },
  "files": [
    "bin/nutshell",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "build:compile": "bun run scripts/build-compile.ts",
    "build:macos-app": "bun run scripts/build-macos-app.ts",
    "install:macos-app": "bun run scripts/build-macos-app.ts --install",
    "build:tarball": "bun run scripts/build-tarball.ts",
    "certify:release": "bun run scripts/certify-release.ts",
    "test:battle": "bun run scripts/battle-test.ts",
    "rehearse:fresh-install": "bun run scripts/fresh-install-rehearsal.ts",
    "rehearse:preflight-host": "bun run scripts/fresh-install-rehearsal.ts preflight-host",
    "rehearse:run": "bun run scripts/fresh-install-rehearsal.ts run",
    "rehearse:verify-clean": "bun run scripts/fresh-install-rehearsal.ts verify-clean",
    "rehearse:verify-installed": "bun run scripts/fresh-install-rehearsal.ts verify-installed",
    "rehearse:verify-unauthenticated": "bun run scripts/fresh-install-rehearsal.ts verify-unauthenticated",
    "rehearse:verify-authenticated": "bun run scripts/fresh-install-rehearsal.ts verify-authenticated",
    "rehearse:verify-final": "bun run scripts/fresh-install-rehearsal.ts verify-final",
    "rehearse:audit-report": "bun run scripts/fresh-install-rehearsal.ts audit-report",
    "rehearse:snapshot-podcasts": "bun run scripts/fresh-install-rehearsal.ts snapshot-podcasts",
    "prepack": "bun run build:compile"
  },
  "devDependencies": {
    "@steipete/bird": "0.8.0",
    "@steipete/sweet-cookie": "0.3.0",
    "@types/bun": "latest",
    "@types/yauzl": "^2.10.3",
    "json5": "^2.2.3",
    "typescript": "^5.9.3",
    "yauzl": "^3.3.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  }
}
