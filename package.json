{
  "name": "nutshell",
  "version": "0.1.0",
  "description": "Local personal trace ingestion runtime for notes, media activity, podcasts, and X.",
  "type": "module",
  "bin": {
    "nutshell": "./bin/nutshell"
  },
  "files": [
    "bin/nutshell",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "build:compile": "bun run scripts/build-compile.ts",
    "build:tarball": "bun run scripts/build-tarball.ts",
    "certify:release": "bun run scripts/certify-release.ts",
    "certify:post-reboot": "bun run scripts/certify-release.ts --post-reboot-check",
    "certify:fresh-user": "bun run scripts/certify-release.ts --fresh-user-check",
    "prepack": "bun run build:compile"
  },
  "devDependencies": {
    "@steipete/bird": "0.8.0",
    "@steipete/sweet-cookie": "0.3.0",
    "@types/bun": "latest",
    "@types/yauzl": "^2.10.3",
    "json5": "^2.2.3",
    "typescript": "^5.9.3",
    "yauzl": "^3.3.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
